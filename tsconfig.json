{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "outDir": "./transpiled",
    "rootDir": "./source",
    "sourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "incremental": true,
    "strict": true,
    "noImplicitOverride": true,
    "allowJs": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "node"
  },
  "include": [
    "source/**/*"
  ]
}
