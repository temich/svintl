{
  "name": "svintl",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Internationalization for Svelte",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/temich/svintl.git"
  },
  "homepage": "git@github.com:temich/svintl#readme",
  "main": "transpiled/index.js",
  "module": "transpiled/index.js",
  "types": "transpiled/index.d.ts",
  "exports": {
    ".": {
      "import": "./transpiled/index.js",
      "require": "./transpiled/index.js",
      "types": "./transpiled/index.d.ts"
    }
  },
  "bin": {
    "intl": "transpiled/cli/index.js"
  },
  "scripts": {
    "prepare": "husky",
    "prepublishOnly": "rm -rf transpiled tsconfig.tsbuildinfo && tsc",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test": "npm run lint && node --test",
    "bump": "npx -y npm-check-updates --target minor -u && npm install"
  },
  "peerDependencies": {
    "svelte": "*",
    "typescript": "^5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "eslint": "^9.33.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "neostandard": "^0.12.2"
  },
  "dependencies": {
    "dotenv": "^17",
    "js-yaml": "^4",
    "openai": "^5"
  }
}
